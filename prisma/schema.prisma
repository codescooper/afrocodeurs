generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  CONTRIBUTOR
  MODERATOR
  ADMIN
}

enum CommunityType {
  SKILL
  GEO
  UNIVERSITY
  SECTOR
  PROJECT
}

enum CommunityMemberRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum KnowledgeType {
  ARTICLE
  TUTORIAL
  GUIDE
  CASE_STUDY
  DOCUMENTATION
  DOSSIER
  TRANSLATION
}

enum ContentStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ProblemStatus {
  PROPOSED
  VALIDATED
  ACTIVE
  ARCHIVED
}

enum QuestionStatus {
  OPEN
  ANSWERED
  SOLVED
  CLOSED
}

enum SolutionType {
  SOFTWARE
  API
  STARTUP
  ORGANIZATION
  SERVICE
}

enum TagType {
  TECHNOLOGY
  SECTOR
  COUNTRY
  SKILL
  TOPIC
  LANGUAGE
}

enum EntityType {
  USER
  PROBLEM
  KNOWLEDGE
  QUESTION
  ANSWER
  COMMUNITY
  SOLUTION
  ORGANIZATION
  TAG
}

enum RelationType {
  RELATED_TO
  EXPLAINS
  SOLVES
  USES
  DISCUSSES
  CREATED_BY
  CONTRIBUTED_TO
  LOCATED_IN
  BELONGS_TO
}

enum ReputationDimension {
  PARTICIPATION
  CONTRIBUTION
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

enum ReportReason {
  SPAM
  HARASSMENT
  PLAGIARISM
  MISINFORMATION
  OFF_TOPIC
  INAPPROPRIATE
  OTHER
}

enum VoteValue {
  UP
  DOWN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  username      String    @unique
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)

  profile       Profile?
  accounts      Account[]
  sessions      Session[]
  communities   CommunityMember[]
  knowledge     Knowledge[]
  problems      Problem[]
  questions     Question[]
  answers       Answer[]
  comments      Comment[]
  votes         Vote[]
  solutions     Solution[]
  reports       Report[] @relation("ReporterReports")
  reputation    ReputationEvent[]
  relations     EntityRelation[] @relation("RelationCreator")
  notifications Notification[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([username])
  @@index([role])
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?
  country      String?
  city         String?
  languages    String[] @default([])
  skills       String[] @default([])
  githubUrl    String?
  linkedinUrl  String?
  websiteUrl   String?
  portfolioUrl String?

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Community {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  type        CommunityType
  country     String?
  city        String?

  members     CommunityMember[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([type])
  @@index([country])
  @@index([city])
}

model CommunityMember {
  id          String              @id @default(cuid())
  userId      String
  communityId String
  role        CommunityMemberRole @default(MEMBER)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  joinedAt    DateTime @default(now())

  @@unique([userId, communityId])
  @@index([communityId])
  @@index([userId])
}

model Problem {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  summary         String?
  description     String
  sector          String
  countries       String[]      @default([])
  impactLevel     Int           @default(1)
  difficultyLevel Int           @default(1)
  status          ProblemStatus @default(PROPOSED)

  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([sector])
  @@index([status])
  @@index([createdById])
}

model Knowledge {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String?
  content     String
  type        KnowledgeType
  language    String        @default("fr")
  level       String?
  status      ContentStatus @default(DRAFT)

  authorId    String
  author      User          @relation(fields: [authorId], references: [id])

  originalContentId String?
  originalContent   Knowledge?  @relation("KnowledgeTranslations", fields: [originalContentId], references: [id])
  translations      Knowledge[] @relation("KnowledgeTranslations")

  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([type])
  @@index([language])
  @@index([status])
  @@index([authorId])
}

model Question {
  id        String         @id @default(cuid())
  title     String
  slug      String         @unique
  body      String
  status    QuestionStatus @default(OPEN)

  authorId  String
  author    User           @relation(fields: [authorId], references: [id])

  answers   Answer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([authorId])
}

model Answer {
  id         String   @id @default(cuid())
  questionId String
  body       String
  isAccepted Boolean  @default(false)

  authorId   String
  author     User     @relation(fields: [authorId], references: [id])

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([questionId])
  @@index([authorId])
}

model Comment {
  id         String     @id @default(cuid())
  body       String

  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  targetType EntityType
  targetId   String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([authorId])
}

model Vote {
  id         String    @id @default(cuid())

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetType EntityType
  targetId   String
  value      VoteValue

  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([userId])
}

model Solution {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  description      String
  type             SolutionType
  country          String?
  websiteUrl       String?
  documentationUrl String?
  license          String?

  createdById      String
  createdBy        User         @relation(fields: [createdById], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([type])
  @@index([country])
  @@index([createdById])
}

model Tag {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  type      TagType

  createdAt DateTime @default(now())

  @@index([slug])
  @@index([type])
}

model EntityRelation {
  id           String       @id @default(cuid())

  sourceType   EntityType
  sourceId     String
  relationType RelationType
  targetType   EntityType
  targetId     String

  createdById  String?
  createdBy    User?        @relation("RelationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt    DateTime     @default(now())

  @@unique([sourceType, sourceId, relationType, targetType, targetId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([relationType])
}

model ReputationEvent {
  id          String              @id @default(cuid())

  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String
  points      Int
  dimension   ReputationDimension

  targetType  EntityType?
  targetId    String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([dimension])
  @@index([targetType, targetId])
}

model Report {
  id          String       @id @default(cuid())

  reporterId  String
  reporter    User         @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  targetType  EntityType
  targetId    String
  reason      ReportReason
  details     String?
  status      ReportStatus @default(OPEN)
  resolution  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
}
