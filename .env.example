# --- Base de données ---
DATABASE_URL="postgresql://afrocodeurs:afrocodeurs@localhost:5432/afrocodeurs?schema=public"

# --- Auth.js / NextAuth ---
# Générer avec : openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# URL publique du site (SEO : metadataBase, robots, sitemap ; liens des emails en prod)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Notifications push (Web Push / VAPID) ---
# Générer une paire : npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@afrocodeurs.org"
# Doit être identique à VAPID_PUBLIC_KEY (exposée au navigateur)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- Recherche (Meilisearch) ---
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# --- Cron (digest hebdomadaire + sync des roadmaps) ---
# Secret protégeant /api/cron/digest et /api/cron/roadmap-sync. Le planificateur
# l'envoie via `Authorization: Bearer <secret>` ou `?key=<secret>`.
CRON_SECRET=""

# --- Roadmaps (synchronisation GitHub) ---
# Optionnel. Sans token, les dépôts PUBLICS sont lisibles (~60 req/h/IP) ; avec un
# token (scope public_repo / read-only), la limite passe à 5000/h — recommandé
# pour le cron en production. Le linking d'identité AfroMaker ↔ GitHub utilise les
# clés OAuth GITHUB_CLIENT_ID/SECRET ci-dessus.
GITHUB_TOKEN=""

# --- Observabilité (Sentry, optionnel) ---
# Sans DSN, les erreurs sont seulement journalisées (cf. lib/observability.ts).
# NEXT_PUBLIC_SENTRY_DSN suffit (client + serveur) ; SENTRY_DSN = DSN serveur distinct.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Upload des source maps au build (optionnel) — sans SENTRY_AUTH_TOKEN, ignoré.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Stockage fichiers (S3 compatible) ---
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# --- Anti-abus (Cloudflare Turnstile, optionnel) ---
# Sans ces clés, le CAPTCHA est désactivé (dev). À définir en production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# --- Emails ---
# Sans RESEND_API_KEY, les emails sont journalisés dans la console (mode dev).
RESEND_API_KEY=""
EMAIL_SERVER=""
EMAIL_FROM="AfroCodeurs <no-reply@afrocodeurs.org>"
